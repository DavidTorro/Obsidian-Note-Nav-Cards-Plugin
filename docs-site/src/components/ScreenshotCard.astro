---
interface Props {
  src: string;
  title: string;
  alt?: string;
  desc?: string;
}

const { src, title, alt, desc } = Astro.props;
const altText = alt ?? title;
---

<figure class="screenshot-card">
  <button
    type="button"
    class="screenshot-card__frame js-lightbox"
    data-full={src}
    data-caption={title}
    aria-label={`Ampliar: ${title}`}
  >
    <img class="screenshot-card__img" src={src} alt={altText} loading="lazy" />
    <span class="screenshot-card__zoom" aria-hidden="true">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="7" />
        <line x1="21" y1="21" x2="16.65" y2="16.65" />
        <line x1="11" y1="8" x2="11" y2="14" />
        <line x1="8" y1="11" x2="14" y2="11" />
      </svg>
    </span>
  </button>
  <figcaption class="screenshot-card__caption">
    <p class="screenshot-card__title">{title}</p>
    {desc && <p class="screenshot-card__desc">{desc}</p>}
  </figcaption>
</figure>
